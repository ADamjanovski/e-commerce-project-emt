# Spring Configuration
SPRING_PROFILES_ACTIVE=dev
SPRING_APPLICATION_NAME=backend

# Database Configuration
DATASOURCE_URL=jdbc:postgresql://localhost:5432/emt?useUnicode=true&characterEncoding=UTF-8&serverTimezone=CET
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=root
DATASOURCE_DRIVER=org.postgresql.Driver

# JPA Configuration
JPA_DDL_AUTO=update
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
HIBERNATE_SHOW_SQL=true
JPA_SHOW_SQL=false
HIBERNATE_QUOTED_IDENTIFIERS=true
HIBERNATE_FORMAT_SQL=true
CLOUD_COMPATIBILITY_VERIFIER=false

# JWT Configuration
JWT_SECRET=7ac51f34954d17b2c22a1a95ea44f1f61c72a0b87d186c8e2c607edb4db99ffd
JWT_EXPIRATION=864000000
JWT_HEADER=Authorization
JWT_PREFIX=Bearer 

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache Configuration
SPRING_CACHE_TYPE=simple

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
